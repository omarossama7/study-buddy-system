generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  userId      String   @id
  courses     String[]
  topics      String[]
  studyPace   String?
  studyMode   String?
  groupSize   Int?
  studyStyle  String?
}
